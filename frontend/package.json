{
  "name": "@family-graph/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-frontend.ps1",
    "dev:vite": "vite --host 127.0.0.1 --port 5400 --strictPort",
    "dev:lan": "vite --host 0.0.0.0 --port 5400 --strictPort",
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-frontend.ps1",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@family-graph/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.3.3",
    "axios": "^1.7.7",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
