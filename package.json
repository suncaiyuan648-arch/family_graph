{
  "name": "family-graph",
  "private": true,
  "version": "0.1.0",
  "description": "家族图谱与家族档案管理系统",
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "dev:backend:full": "npm --workspace backend run dev:full",
    "dev:web": "npm run dev:frontend",
    "dev:api": "npm run dev:backend",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck",
    "prisma:generate": "npm --workspace backend run db:generate",
    "prisma:migrate": "npm --workspace backend run db:migrate",
    "prisma:seed": "npm --workspace backend run db:seed"
  },
  "prisma": {
    "seed": "npm --workspace backend run db:seed"
  },
  "workspaces": [
    "frontend",
    "frontend/shared",
    "backend"
  ],
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.6.3"
  }
}
